{
  "name": "newtaboberride",
  "version": "18.0.0",
  "description": "New Tab Override brings back the ability to change the page which is shown when opening a new tab.",
  "author": {
    "name": "Sören Hentzschel",
    "email": "kontakt@agenedia.com",
    "url": "https://agenedia.com"
  },
  "homepage": "https://www.soeren-hentzschel.at/firefox-webextensions/new-tab-override/?utm_campaign=webext&utm_term=newtaboverride",
  "bugs": {
    "email": "kontakt@agenedia.com"
  },
  "license": "MPL 2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/cadeyrn/newtaboverride/"
  },
  "private": true,
  "browserslist": [
    "Firefox >= 140"
  ],
  "devDependencies": {
    "@eslint/json": "2.0.1",
    "@html-eslint/eslint-plugin": "0.64.0",
    "@stylistic/eslint-plugin": "5.10.0",
    "eslint": "10.7.0",
    "eslint-plugin-jsdoc": "63.0.7",
    "eslint-plugin-xss": "0.1.12",
    "stylelint": "17.13.0",
    "stylelint-order": "8.1.1",
    "web-ext": "10.4.0"
  },
  "scripts": {
    "build": "web-ext build --source-dir ./src --artifacts-dir ./dist --filename {name}-{version}.xpi --overwrite-dest",
    "lint": "node lint.mjs",
    "lint:css": "stylelint ./src/css/**/*.css",
    "lint:html": "eslint ./src/html/**/*.html",
    "lint:js": "eslint ./src/js/**/*.js ./src/_locales/**/*.json",
    "lint:locales": "node lint-locales.mjs",
    "lint:web-ext": "web-ext lint --source-dir ./src",
    "run:nightly": "web-ext run --source-dir ./src --firefox=nightly",
    "run:beta": "web-ext run --source-dir ./src --firefox=beta",
    "run:stable": "web-ext run --source-dir ./src --firefox=firefox",
    "run:esr": "web-ext run --source-dir ./src --firefox=\"/Applications/Firefox ESR.app\""
  }
}
